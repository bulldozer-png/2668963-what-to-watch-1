<?xml version="1.0"?>
<psalm
    errorLevel="3"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:noNamespaceSchemaLocation="https://getpsalm.org/xml/schema/psalm.xsd"
>
    <projectFiles>
        <directory name="app" />
        <directory name="bootstrap" />
        <directory name="config" />
        <directory name="database" />
        <directory name="resources" />
        <directory name="routes" />
    </projectFiles>

    <plugins>
        <pluginClass class="Psalm\LaravelPlugin\Plugin" />
        <pluginClass class="Psalm\PhpUnitPlugin\Plugin" />
    </plugins>

    <issueHandlers>
        <MissingReturnType errorLevel="info" />
        <MissingParamType errorLevel="info" />
        <MixedOperand errorLevel="info" />
        <MixedAssignment errorLevel="info" />
        <PossiblyUnusedMethod errorLevel="info" />
        <PossiblyUnusedParam errorLevel="info" />
        <UnusedClass errorLevel="info" />
        <UnusedClosureParam errorLevel="info" />
        <MissingOverrideAttribute errorLevel="info" />
        <UndefinedMagicPropertyFetch errorLevel="info" />
        <UndefinedMagicMethod errorLevel="info" />
        <InvalidArgument errorLevel="info" />
        <InvalidScope errorLevel="info" />
        <UndefinedDocblockClass errorLevel="info" />
        <MoreSpecificReturnType errorLevel="info" />
        <PossiblyNullArgument errorLevel="info" />
        <UndefinedThisPropertyFetch errorLevel="info" />
        <InvalidDocblock errorLevel="info" />
        <MoreSpecificReturnType errorLevel="info" />
        <PossiblyNullArgument errorLevel="info" />
        <PossiblyNullPropertyAssignmentValue errorLevel="info" />
        <RedundantCondition errorLevel="info" />
    </issueHandlers>
</psalm>
